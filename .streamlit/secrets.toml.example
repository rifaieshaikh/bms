# Optional seeding (highest precedence over env and seed.toml).
# Prefer bms/seed.toml for day-to-day; use secrets for Streamlit Cloud.
# Precedence per key: secrets → env → seed.toml → default
#
# Single control — set a profile to seed business + catalog + parties:
# SEED_PROFILE = "none"              # disabled (default)
# SEED_PROFILE = "boutique"          # one vertical
# SEED_PROFILE = "pharma,hardware"   # several; uses [business.multi]
# SEED_PROFILE = "all"               # every vertical
#
# SEED_CONFIG = true
# SEED_QA_FIXTURES = false
# PURGE_BUSINESS_DATA = false
# SEED_CUSTOMER_COUNT = 100
# SEED_VENDOR_COUNT = 100
# SEED_CATEGORY_COUNT = 100
# SEED_PRODUCT_COUNT = 100
#
# [business.boutique]
# legal_name = "Kochi Silk Boutique"
# ...
# [business.multi]
# legal_name = "Seed Multi Vertical Demo"
